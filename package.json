{
  "name": "my-turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "up": "npm --workspace @repo/db run db:migrate",
    "db:migrate:undo": "npm --workspace @repo/db run db:migrate:undo",
    "db:create": "npm --workspace @repo/db run db:create",
    "db:drop": "npm --workspace @repo/db run db:drop",
    "db:seed": "npm --workspace primary-backend run db:seed"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.5",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@9.2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
